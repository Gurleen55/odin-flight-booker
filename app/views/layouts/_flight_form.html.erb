<%= form_with(url: flights_path, method: :get) do |form| %>
    <%= form.label :departure_airport_id, "Select Departure Airport" %>
    <%= form.select(:departure_airport_id, available_airports, include_blank: true) %> 
    <%= form.label :arrival_airport_id, "Select Departure Airport" %>
    <%= form.select(:arrival_airport_id, available_airports, include_blank: true) %> 
    <%= form.label :time, "Date"%>
    <%= form.select(:time, available_times, include_blank: true) %>
    <%= form.label :number_of_passengers, "Number Of Passengers" %>
    <%= form.select(:number_of_passengers, options_for_select([[1,1],[2,2],[3,3],[4,4]]))%>
    <%= form.submit "Search Flights"%>
<% end %>